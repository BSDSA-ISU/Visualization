

















import pandas as pd


import matplotlib.pyplot as plt


import seaborn as sns





df = pd.read_csv("ERA.csv")


print(df.head(5))





df.info()





print(df.columns)





print("Mean:",df["Total_Students"].mean())
print("Median:", df["Total_Students"].median())
print("Mode:", df["Total_Students"].mode())
print("Standard Deviation:", df["Total_Students"].std())
print("Min value:", df["Total_Students"].min())
print("Max value:", df["Total_Students"].max())












df["Region"].value_counts(normalize=True)*100



df["Region"].value_counts()








sns.histplot (df["Region"])


sns.histplot(df["Institution_Type"])





num_cols = df.select_dtypes(include="number").columns

for col in num_cols:
    sns.boxplot(df[col], fill=True)
    plt.title(col)
    plt.show()











sns.stripplot(data=df, x="Institution_Type", y="Total_Students")





num_cols = df.select_dtypes(include="number").columns

for col in num_cols:
    sns.kdeplot(df[col], fill=True)
    plt.title(col)
    plt.show()





sns.histplot(df["Total_Students"], kde=True)





sns.barplot(data=df, x="Institution_Type", y="Total_Students")





num_cols = df.select_dtypes(include="number").columns

for col in num_cols:
    sns.histplot(df[col], kde=True)
    plt.title(col)
    plt.show()





df["Region"].value_counts().plot.pie(autopct="%1.1f%%")






